# Bulky font source folders — committed copies live at public/fonts/*.woff2 / *.otf
public/fonts/Sackers/
public/fonts/Unica 77 LL/
public/fonts/Avenir/

# Working assets folder — site uses public/work/ (lowercase). public/ALL WORK/
# is Emily's source-asset organisation folder; raw GIFs/MP4s in there can
# easily exceed GitHub's 100 MB file limit.
public/ALL WORK/

# Same situation for POP UP FILES — Emily's per-project source folder used
# for organising case study assets before they get moved into /work/<slug>/.
# Raw GIFs in here have exceeded GitHub's 100MB hard limit.
public/work/POP UP FILES*/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Oversized source gifs in cultural strategy folder (we ship the .mp4 conversions)
public/Cultural Strategy/:cultural strategy/*.gif
